{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/client.js", "destination": "/public/client.js" },
    { "source": "/styles.css", "destination": "/public/styles.css" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
